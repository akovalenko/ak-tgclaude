# ak-tgclaude — example bot configuration (TOML).
#
# Copy to bot.toml and fill in. Every field can also be passed on the command
# line (flags override the file); the CLI exists for a quick "just try it" run:
#
#   ak-tgclaude dispatch --bot-token 123:ABC --profile qa --project ~/code
#
# In production prefer this file over --bot-token: a token in a file is
# protected by sandbox.credentials.files (deny-read inside the responder's
# sandbox), whereas a token on the command line is visible in the host's
# process list (ps) to other local processes.

# Telegram bot token (secret). Kept only in the dispatcher's memory; never
# exported to the environment. Required.
bot_token = "123456789:AA...replace-me..."

# Responder agent name (claude -p --agent). Default: the shipped "faq-responder"
# (read-only FAQ assistant, materialized into the scaffold). Point at your own
# domain agent to override — have it pull in the "tg-emit" skill so it replies
# through ak-tgclaude send.
# agent = "faq-responder"

# Extra raw arguments appended to the responder's `claude -p` (e.g. pick the model
# or reasoning effort). Any current/future claude flag works here; also repeatable
# --claude-arg (one token each) and --claude-args "--model opus --effort high" (one
# whitespace-split string) — all three additive. Flags ak-tgclaude owns (--permission-mode,
# --setting-sources, --mcp-config/--strict-mcp-config, --allowedTools, --settings,
# --agent, --resume/--continue, -p/--output-format/--input-format, and the
# skip-permissions escapes) are REJECTED at startup — they govern the sandbox,
# transport, session, and output parsing.
# claude_args = ["--model", "opus", "--effort", "high"]

# Access profile: "qa" (read-only, default) | "dev" | "ops".
# Only "qa" is implemented for now; dev/ops are reserved for a future
# remote-development pivot. The profile drives the responder's permissions and
# what its PreToolUse hook allows.
profile = "qa"

# Responder implementation: "claude" (default) spawns `claude -p`; "stub"
# replies a fixed line ("i am here") for smoke-testing the Telegram I/O path
# without a model or scaffold (needs only bot_token, no project).
# responder = "claude"

# The project the bot consults on. Read-only under the qa profile; the sandbox
# and PreToolUse confine the responder's reads here. Required.
project = "~/code/example-project"

# Extra paths the responder must NEVER read, on top of the always-denied host
# secrets (SSH keys, Claude creds/history, other sessions' transcripts, the token
# file). Each is denied at BOTH layers: the PreToolUse hook blocks the Read tool
# (wins even for a path inside the project), and sandbox.filesystem.denyRead blocks
# the sandboxed Bash (cat/grep). Takes ~; a relative path resolves against the
# launch cwd (like every path here). Also --deny-read (repeatable; merged).
# deny_reads = ["~/code/example-project/secrets.env", "~/.aws"]

# Extra egress domains for the responder's sandbox (sandbox.network.allowedDomains),
# ON TOP of the always-present Go-build defaults (proxy.golang.org, sum.golang.org,
# storage.googleapis.com). This is the sandboxed-Bash egress layer — a responder
# curl / go get may reach the listed host — SEPARATE from a WebFetch(domain:X) tool
# grant (see tools below), which scopes the WebFetch TOOL and, under claude -p, does
# NOT open sandbox egress. A leading *. matches subdomains only, NOT the apex
# github.com (list both if you need the apex). Additive + de-duplicated. Also
# --allow-domain (repeatable; merged).
# allow_domains = ["*.githubusercontent.com", "api.github.com"]

# Access control: Telegram user ids allowed to use the bot. Empty (the default)
# denies everyone — the bot answers /start and /help with "no access for id N"
# (so a user can report the id) and silently ignores everything else. To find
# your own id, start the bot and send it /start. Also --allow-user (repeatable).
# In a GROUP this gate is still per-sender: being a member does not authorize you,
# and the bot answers only an authorized member who @mentions it or uses /do (turn
# BotFather group privacy OFF so it can see group messages). See the README "Groups".
# allowed_users = [123456789]

# OPEN ACCESS: allow every Telegram user, no whitelist. DEMO ONLY — exposes the
# bot (and the project it answers about) to anyone who finds it. Logged loudly at
# startup. Also --open.
# open_access = false

# --- optional overrides (defaults shown) ---

# Reply to /help and /start (the dispatcher answers these itself, no model spawn).
# Empty/unset uses a generic built-in blurb about the bot's mechanics; set this
# to describe your specific bot/project. The /clear and /help command menu is
# uploaded to Telegram at startup regardless.
# help_text = "I answer questions about the Foo codebase — adapters, deploy, protocols. Just ask; /clear starts fresh."

# Send help_text as Telegram HTML (<b> <i> <a href="…">, with & < > escaped)
# instead of plain text. Default false. Set only when help_text is valid HTML —
# invalid markup makes Telegram reject the reply (logged, help just won't send).
# help_html = false

# Max responders running at once. Updates are always serialized per chat;
# different chats run concurrently up to this bound.
# max_concurrent = 4

# Max size (MB) of an incoming document or photo the bot downloads into the
# responder's outbox (under incoming/) for it to read or Edit; a larger
# attachment is refused with a note to the user. Default 20 — the Telegram
# bot-API getFile ceiling, above which the bot cannot fetch a file at all.
# max_incoming_mb = 20

# After each answer, send the run's dollar cost as a bare "$n.nnn" message
# (tenth-of-a-cent precision) to the chat — sent only when the cost is present
# and non-zero, otherwise nothing. Under a Claude subscription the figure is
# notional (what the run would cost at API rates), not real billing. Also --bill.
# bill = false

# Append-only JSONL usage log: one line per answered round, for cost/latency
# analytics. The PATH is the switch — set it to enable, leave empty (default) to
# write nothing. Each line is {ts, chat_id, user_id, msg_id, elapsed, cost}: ts is
# the round's start (RFC3339, local zone, whole seconds); msg_id is the incoming
# message id (joins the transcript store); elapsed is the whole-round
# wall-clock in seconds (a delivery-guard re-prompt is counted in); cost is the
# summed total_cost_usd (0 when absent). Written by the dispatcher. On the READ
# side it is owner-only: the owner's responder is granted sandboxed read of it
# (for cost questions, via the tg-usage skill), every other responder is denied
# read. The parent dir is created if missing. Also --usage-log.
# usage_log = "/var/lib/ak-tgclaude/usage.jsonl"

# Keep the chat->session map in memory only: it is never written to disk, so
# every restart starts each chat fresh. The getUpdates offset still persists (a
# restart won't reprocess the backlog). Default false (bindings persist). Also
# --ephemeral-sessions. For a one-shot wipe without going ephemeral, run the
# `clear` subcommand instead.
# ephemeral_sessions = false

# Workaround for Claude Code bug #64301: sandboxed Bash blind-escapes `!`->`\!`,
# silently corrupting the command/output. With this on, the PreToolUse hook denies
# any sandboxed Bash whose command contains `\!` and tells the model to write the
# script to a file instead (which the sandbox runs verbatim). Default false —
# it's a workaround, and a legitimate `\!` (e.g. `find . \!`) is caught too. Also
# --bang-bug.
# bang_bug = false

# Delivery guard (ON by default). The responder delivers an answer only by calling
# a send tool; its final text is a discarded status signal. A weaker model sometimes
# ends a turn without sending — dumping its answer into that discarded text, so the
# user gets nothing. When guarded, the dispatcher notices a turn delivered zero
# messages and re-prompts the same session once to actually send. Set allow_silent
# (or --allow-silent) only if a no-send turn is legitimate for your bot.
# allow_silent = false
#
# Fallback reply sent when the guard's re-prompt STILL delivered nothing. Empty
# (default) => the guard only re-prompts and logs, sending no fabricated message.
# undelivered_text = "Sorry, I could not answer that."

# Grant EXTRA tools to the responder. Each value is split across the two grants that
# must change together: its bare NAME goes into the agent's tools: frontmatter
# (availability) and the value VERBATIM into --allowedTools (permission). So a scoped
# spec like WebFetch(domain:*.github.com) grants bare WebFetch availability plus that
# domain scope; two scopes of one verb collapse to a single name in the frontmatter
# while both ride --allowedTools. Values are tool names, scoped specs, or MCP patterns
# (Agent, WebFetch(domain:X), mcp__srv__*). SHARP knob: the sandbox still confines Bash
# and the hook still gates the file tools, but a tool the hook does NOT gate (WebFetch,
# Agent, ...) genuinely widens access. Also repeatable --tool (quote a scoped spec).
# tools = ["Agent", "WebFetch(domain:*.github.com)"]

# DEFAULT responder persona, composed and injected at spawn via
# --append-system-prompt: an ARRAY (plural key) of built-in names — "normal"
# (declines off-topic, the default) | "norefuse" (do-what-you're-asked) | "strict"
# (refuses anything but direct project questions) | "introspect" (candid/debug:
# precise about failures, explains the machinery) | "outbox-rw" (do read-write tasks —
# build/test a scratch clone — via the outbox instead of refusing as read-only) —
# and/or paths to your own .md fragments, merged in order into one persona. A fragment
# may declare `axis:` in its frontmatter (e.g. the refusal trio normal/norefuse/strict
# all carry `axis: refusal`); two entries sharing an axis fail at load. Machine guards
# (read-only sandbox, token deny, per-chat route) apply to every persona, so none
# can exceed the read-only contract. Repeatable --policy is additive with this list;
# `ak-tgclaude <cmd> --policy help` prints the built-in catalog and exits.
# policies = ["normal"]

# Default persona for GROUP chats (the parallel of `policies` for one-on-one chats),
# layered on `policies` along axes. In a group the persona is a property of the group,
# not of whoever speaks first. Empty => groups use the plain `policies` default. Same
# selectors as `policies`; also --group-policy (repeatable, additive).
# group_policies = ["norefuse"]

# Persona overrides, keyed by Telegram id. Layered on a base ALONG AXES: a fragment
# that declares an axis EVICTS the base fragment on that same axis, an axis-less one
# is appended. The key's SIGN picks the base: a POSITIVE key is a user id (applies in
# that user's DM, layered on `policies`); a NEGATIVE key is a group chat id (applies
# in that group, layered on `group_policies`). The two never collide.
# [policy_overrides]
# 12345678 = ["norefuse", "introspect"]        # a user, in their DM: policies + this
# -1001234567890 = ["introspect"]              # a specific group: group_policies + this

# Owner shortcut: a Telegram user id that is auto-whitelisted (added to
# allowed_users) AND granted the relaxed owner persona (norefuse + introspect),
# unless it has an explicit policy_overrides entry. One knob for "owner = admin".
# The id must be supplied — the Bot API's getMe does not reveal the bot's owner.
# Also --owner.
# owner = 12345678

# Static workdir. When set, the responder cwd is $workdir/project — regenerated
# from canon on every start (contents reset, then re-materialized, so a removed
# wire-skill never lingers) — and the session store moves to $workdir/state.
# $workdir/project is marked trusted once in ~/.claude.json, so its
# permissions.allow is honored and (on a vanilla build) Grep/Glob are registered.
# NOT a hand-drop dir: add skills via wire_skills, not by hand. Default: an
# ephemeral cwd removed on shutdown. See also the `scaffold` subcommand. Also
# --workdir.
# workdir = "~/qa"

# Base directory under which the ephemeral responder cwd is created (a
# pseudo-random subdir is made inside it). Default: $XDG_RUNTIME_DIR, else a
# temp dir. Only applies to the ephemeral cwd — rejected together with workdir
# (which uses a fixed $workdir/project instead).
# runtime_base = ""

# Durable dispatcher state (chat->session and message->session maps), which must
# survive restarts. Default: $XDG_STATE_HOME/ak-tgclaude (~/.local/state/ak-tgclaude).
# state_dir = ""

# --- per-chat transcripts & recall (optional; default OFF) ---
# transcripts records every turn (user message + bot reply) as compact JSONL
# day-files under <root>/<chat_id>/, so the responder can read its own history back
# (context recovery, replied-to messages, an owner "what did people ask this week"
# writeup — via the tg-recall skill). It is OFF by default because it writes users'
# message text to disk. The flag gates both the recording and the skill. Also
# --transcripts. See the Transcripts & recall section in the README.
# transcripts = false
#
# Override the store root. Default: <state>/transcripts (survives restarts and the
# session-TTL outbox wipe). An override must live OUTSIDE the responder outbox, or
# startup fails. Prune retention yourself: find <root> -name '*.jsonl' -mtime +N -delete.
# Also --transcript-dir.
# transcript_dir = ""
#
# With transcripts on, the owner (see `owner` above) reads the WHOLE store for
# cross-chat analytics; everyone else is scoped to their own chat. The scope always
# comes from the trusted sender id, never the model. Set false to scope the owner
# like any user (e.g. when the bot is opened to colleagues). Default true. Also
# --owner-reads-all.
# owner_reads_all = true

# --- large-file fallback for send_document (optional) ---
# Telegram's bot API caps an attachment near 50 MB. Point upload_command at an
# UPLOADER script and any document over upload_threshold_mb is uploaded instead
# and delivered to the chat as a link. The dispatcher runs it UNSANDBOXED (it needs
# the network); the responder just calls send_document as usual. Contract: invoked
# as argv [command, <file>, <name>] — <file> is the local path, <name> is a
# collision-free basename (random prefix + original name, e.g. a3f9c2e1-dist.tar.gz)
# the uploader MAY use as its destination so two same-named files don't clobber each
# other on the share host (an uploader that doesn't need arg2 may ignore it, but must
# not REJECT a second argument). The name keeps the original filename, so it may hold
# non-ASCII (e.g. Cyrillic) — an uploader building a URL should percent-encode it. It
# must print the public URL on stdout (first non-blank line) and exit 0, or exit
# non-zero with a message on stderr. See examples/rsync-upload.sh for a ready one.
# Empty (default) => off; big documents then hit Telegram's limit.
# upload_command = "~/uploaders/rsync-upload.sh"
#
# Size (MB) above which a document is uploaded rather than attached. Default 40
# (headroom under Telegram's ~50 MB). Ignored without upload_command.
# upload_threshold_mb = 40
#
# Advertised max (MB) surfaced to the responder ("you can send files up to N MB").
# Enforcement sits 10% above it, so a file a touch over still uploads; anything
# larger is rejected with a clear "too large even for the cloud" error. 0 (default)
# => no advertised number and no hard cap (only the threshold routing applies).
# upload_max_mb = 300
